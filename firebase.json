{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "dugun-planlayici-ff34e",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "CLAUDE.md",
      "BACKLOG.md",
      "SESSION_LOG.md",
      ".claude/**",
      ".git/**",
      "memory/**",
      "*.md"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=300, must-revalidate" }
        ]
      }
    ]
  }
}
