rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sahipler: İbrahim ve Hilal — tüm veriye erişir
    // v1.0'da UID allowlist → wedding membership modeline geçilecek
    function isOwner() {
      return request.auth != null &&
        request.auth.uid in ['2A9tYioQs8SmZC4v6QgZ2ct4bHI2', 'xJt5BecC3yQLAIxFGGTvj3gs37m1'];
    }

    // Düzenleyici: e-postası shared/editors dokümanındaki "emails" listesinde
    // olan kişi. Kod/kural içine e-posta gömülmez — e-posta eklemek/çıkarmak
    // anında yetki verir/keser, kural deploy'u gerekmez.
    function isGuestEditor() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email in
          get(/databases/$(database)/documents/shared/editors).data.emails;
    }

    // ── Sahipler: her şey (mevcut davranış, değişmedi) ──────────────
    match /{document=**} {
      allow read, write: if isOwner();
    }

    // ── Düzenleyici: YALNIZCA davetli listesi + versiyon geçmişi ────
    // shared/editors dahil diğer tüm dokümanlar düzenleyiciye kapalı.
    match /shared/guests {
      allow read, update: if isGuestEditor();

      // Versiyonlama düzenleyici kayıtlarında da çalışsın
      match /history/{v} {
        allow read, write: if isGuestEditor();
      }
    }
  }
}
